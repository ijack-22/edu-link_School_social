# ============================================
# EduLink Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
#
# For Expo, variables must be prefixed with EXPO_PUBLIC_
# to be available in the client bundle.
# ============================================

# Supabase Project URL (found in Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous / Public Key (found in Project Settings → API → anon/public)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
